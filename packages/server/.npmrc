; Elastic Beanstalk runs `npm install --omit=dev` in this directory and there's
; no co-located lockfile (the workspace lockfile lives at the monorepo root).
; The AWS SDK packages publish on a rapid daily cadence and occasionally release
; client-X and lib-X with mismatched peer ranges for an hour or two; ERESOLVE
; would otherwise fail the deploy. The packages are API-compatible across
; minors so this is safe.
legacy-peer-deps=true
